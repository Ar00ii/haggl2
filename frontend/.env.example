# ──────────────────────────────────────────────────────────────────────
# haggl frontend — environment variables
# ──────────────────────────────────────────────────────────────────────
# Copy to `frontend/.env.local` for local dev. On Vercel set these in
# Project Settings → Environment Variables.

# ── Backend connection ───────────────────────────────────────────────
# Local:      http://localhost:3001/api/v1
# Production: https://api.haggl.tech/api/v1  (or the Render URL)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Local:      http://localhost:3001
# Production: https://api.haggl.tech (same host as API_URL minus path)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── Optional: on-chain ───────────────────────────────────────────────
# Address of the deployed escrow program. Used by the publish flow on
# the client side. Leave blank for read-only / pre-launch builds.
NEXT_PUBLIC_ESCROW_CONTRACT=
